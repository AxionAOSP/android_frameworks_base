<resources>
   <!-- Settings Restart -->
    <java-symbol type="string" name="settings_restart_title" />
    <java-symbol type="string" name="settings_restart_message" />
    <!-- Soft restart dialog -->
    <java-symbol type="string" name="system_restart_title" />
    <java-symbol type="string" name="system_restart_message" />
    <!-- SystemUI restart dialog -->
    <java-symbol type="string" name="systemui_restart_title" />
    <java-symbol type="string" name="systemui_restart_message" />
    <!-- Launcher restart dialog -->
    <java-symbol type="string" name="launcher_restart_title" />
    <java-symbol type="string" name="launcher_restart_message" />

    <!-- Pocket mode -->
    <java-symbol type="layout" name="pocket_mode_layout" />
    <java-symbol type="drawable" name="prevent_mode_img" />
    <java-symbol type="id" name="pocket_mode_phone_image" />
    <java-symbol type="id" name="pocket_mode_active_message" />
    <java-symbol type="id" name="pocket_mode_hint_message" />
    <java-symbol type="string" name="pocket_mode_active" />
    <java-symbol type="string" name="pocket_mode_hint" />

    <!-- App lock -->
    <java-symbol type="string" name="unlock_application" />
    <java-symbol type="array" name="config_appLockAllowedSystemApps" />
    
    <!-- Whether to cancel fingerprint operation if not idle -->
    <java-symbol type="bool" name="config_fpCancelIfNotIdle" />

    <!-- Lock gesture -->
    <java-symbol type="string" name="gesture_locked_warning" />

    <!-- Whether to force enable multi resolution configuration for camera -->
    <java-symbol type="bool" name="config_forceMultiResolution" />

     <!-- Mock Oplus LinearmotorVibratorService -->
    <java-symbol type="bool" name="config_mockOplusLinearmotorVibratorService" />
</resources>
