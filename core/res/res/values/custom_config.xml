<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Whether to cancel fingerprint operation if not idle -->
    <bool name="config_fpCancelIfNotIdle">false</bool>
    
    <!-- Component name of the activity that allows choosing the usb function when a usb device is plugged in. -->
    <string name="config_usbFunctionActivity" translatable="false">com.android.systemui/com.android.systemui.usb.UsbFunctionActivity</string>
     
    <!-- Keybox configuration for device certification -->
    <string-array name="config_certifiedKeybox" translatable="false">
      <!--
        Keybox entries for EC and RSA keys and certificates.
        These should be populated with valid data for device certification.
        <item>EC.PRIV:</item>
        <item>EC.CERT_1:</item>
        <item>EC.CERT_2:</item>
        <item>EC.CERT_3:</item>
        <item>RSA.PRIV:</item>
        <item>RSA.CERT_1:</item>
        <item>RSA.CERT_2:</item>
        <item>RSA.CERT_3:</item>
      -->
    </string-array>
</resources>
