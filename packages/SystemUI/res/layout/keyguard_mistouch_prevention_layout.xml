<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.mistouch.MistouchPreventionView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:background="#ff000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.9"/>
    <ImageView
        android:id="@+id/keyguard_mistouch_prevention_device_outline"
        android:layout_width="match_parent"
        android:layout_height="@dimen/keyguard_mistouch_prevention_outline_height"
        android:layout_marginTop="@dimen/keyguard_mistouch_prevention_outline_margin_top"
        android:src="@drawable/keyguard_mistouch_prevention"/>
    <TextView
        android:textSize="@dimen/keyguard_mistouch_prevention_description_text_size"
        android:textColor="@color/keyguard_mistouch_prevention_text_color"
        android:gravity="center"
        android:id="@+id/mistouch_description"
        android:layout_width="@dimen/keyguard_mistouch_prevention_description_width"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/keyguard_mistouch_prevention_description_margin_top"
        android:text="@string/keyguard_mistouch_description"
        android:layout_alignTop="@+id/keyguard_mistouch_prevention_device_outline"
        android:layout_centerHorizontal="true"
        android:lineSpacingMultiplier="1.3"
        android:fontFamily="@*android:string/config_bodyFontFamily"
        android:letterSpacing="0.037"/>
    <TextView
        android:textSize="@dimen/keyguard_mistouch_prevention_title_text_size"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:id="@+id/keyguard_mistouch_title"
        android:layout_width="@dimen/keyguard_mistouch_prevention_title_and_exit_width"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/keyguard_mistouch_prevention_title_margin_top"
        android:text="@string/keyguard_mistouch_title"
        android:layout_below="@+id/keyguard_mistouch_prevention_device_outline"
        android:layout_centerHorizontal="true"
        android:fontFamily="@*android:string/config_headlineFontFamily"/>
    <TextView
        android:textSize="@dimen/keyguard_mistouch_prevention_exit_text_size"
        android:textColor="@color/keyguard_mistouch_prevention_text_color"
        android:gravity="center"
        android:id="@+id/keyguard_mistouch_exit_desciption"
        android:layout_width="@dimen/keyguard_mistouch_prevention_title_and_exit_width"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/keyguard_mistouch_prevention_exit_margin_top"
        android:text="@string/keyguard_mistouch_exit_desciption"
        android:layout_below="@+id/keyguard_mistouch_title"
        android:layout_centerHorizontal="true"
        android:fontFamily="@*android:string/config_bodyFontFamilyMedium"
        android:letterSpacing="0.01"/>
</com.android.systemui.mistouch.MistouchPreventionView>
