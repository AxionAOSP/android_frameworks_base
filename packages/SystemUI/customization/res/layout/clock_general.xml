<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.shared.clocks.view.GeneralClockView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/container_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:layout_gravity="start|bottom"
            android:id="@+id/info_placeholder_text_view"
            android:padding="0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/clock_text_placeholder"
            android:includeFontPadding="false"
            android:layout_alignParentBottom="true"
            android:lineSpacingExtra="0dp"
            android:lineSpacingMultiplier="1"
            android:fontFamily="nothingdot"
            android:layoutDirection="ltr"
            android:layout_alignParentStart="true"
            android:textFontWeight="400"/>
        <TextView
            android:ellipsize="end"
            android:id="@+id/info_top_text_view"
            android:padding="0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:layout_above="@+id/info_bottom_container_layout"
            android:lineSpacingExtra="0dp"
            android:lineSpacingMultiplier="1"
            android:layout_alignParentStart="true"
            android:textFontWeight="500"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/info_bottom_container_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true">
            <TextView
                android:ellipsize="end"
                android:id="@+id/info_front_text_view"
                android:padding="0dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:lineSpacingExtra="0dp"
                android:lineSpacingMultiplier="1"
                android:textFontWeight="500"/>
            <ImageView
                android:id="@+id/quick_look_icon_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:ellipsize="end"
                android:id="@+id/info_rear_text_view"
                android:padding="0dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:lineSpacingExtra="0dp"
                android:lineSpacingMultiplier="1"
                android:textFontWeight="500"/>
        </LinearLayout>
    </RelativeLayout>
</com.android.systemui.shared.clocks.view.GeneralClockView>
