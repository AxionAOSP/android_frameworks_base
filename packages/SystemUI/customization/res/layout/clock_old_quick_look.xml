<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.shared.clocks.view.OldQuickLookClockView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/container_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:ellipsize="none"
            android:gravity="left"
            android:id="@+id/clock_text_view"
            android:paddingTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:fontFamily="nothingdot57"
            android:textFontWeight="700"/>
        <LinearLayout
            android:layout_gravity="left"
            android:orientation="horizontal"
            android:id="@+id/date_container_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:gravity="left"
                android:id="@+id/date_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clock_image_placeholder"
                android:fontFamily="nothingdot"
                android:textFontWeight="400"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/alarm_icon_view"
                android:visibility="gone"
                android:layout_width="@dimen/old_clock_alarm_icon_primary_size"
                android:layout_height="@dimen/old_clock_alarm_icon_primary_size"
                android:src="@drawable/old_quick_look_alarm_icon"/>
            <TextView
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:id="@+id/alarm_info"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textFontWeight="400"/>
        </LinearLayout>
        <TextView
            android:layout_gravity="left"
            android:id="@+id/placeholder_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/clock_old_quick_look_image_placeholder"
            android:fontFamily="nothingdot"
            android:textFontWeight="400"/>
        <LinearLayout
            android:layout_gravity="left"
            android:orientation="horizontal"
            android:id="@+id/weather_container_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/weather_icon_view"
                android:layout_width="@dimen/old_clock_icon_primary_size"
                android:layout_height="@dimen/old_clock_icon_primary_size"/>
            <TextView
                android:ellipsize="end"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/weather_info_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:textFontWeight="400"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/calendar_info_container_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/now_playing_icon"
                    android:layout_width="@dimen/old_clock_icon_primary_size"
                    android:layout_height="@dimen/old_clock_icon_primary_size"/>
                <TextView
                    android:ellipsize="end"
                    android:layout_gravity="start|center_vertical"
                    android:id="@+id/calendar_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:fontFamily="nothingdot"
                    android:textFontWeight="400"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:ellipsize="end"
                    android:layout_gravity="start"
                    android:id="@+id/calendar_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:fontFamily="nothingdot"
                    android:textFontWeight="400"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.android.systemui.shared.clocks.view.OldQuickLookClockView>
